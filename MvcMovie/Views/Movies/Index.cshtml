@model MvcMovie.Models.MovieGenreYearViewModel

@{
    ViewData["Title"] = "My Movies";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<form asp-action="Index" method="get" class="row g-3 align-items-end mb-3">
    <div class="col-12 col-md-4">
        <label class="form-label" asp-for="SearchString">Title contains</label>
        <input asp-for="SearchString" class="form-control" />
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label" asp-for="MovieGenre">Genre</label>
        <select asp-for="MovieGenre" class="form-select" asp-items="Model.Genres">
            <option value="">All</option>
        </select>
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label" asp-for="MovieYear">Year or newer</label>
        <select asp-for="MovieYear" class="form-select" asp-items="Model.Years">
            <option value="">All</option>
        </select>
    </div>
    <div class="col-12 col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Search</button>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Title</th>
            <th>Release Date</th>
            <th>Genre</th>
            <th>Price</th>
            <th>Rating</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Movies)
{
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Title)</td>
            <td>@Html.DisplayFor(modelItem => item.ReleaseDate)</td>
            <td>@Html.DisplayFor(modelItem => item.Genre)</td>
            <td>@Html.DisplayFor(modelItem => item.Price)</td>
            <td>@Html.DisplayFor(modelItem => item.Rating)</td>
            <td class="text-end">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
